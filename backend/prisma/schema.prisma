generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MODERATOR
  PARTICIPANT
}

enum ScenarioDomain {
  CROP_PRODUCTION
  GREENHOUSE
  LIVESTOCK
  LOGISTICS
  PROCESSING
  ROBOTICS
  TEAMBUILDING
}

enum SessionStatus {
  PLANNED
  ACTIVE
  FINISHED
}

enum EventType {
  PRODUCTION_PROBLEM
  WEATHER_CHANGE
  RESOURCE_LIMIT
  EQUIPMENT_FAILURE
  TEAM_CONFLICT
  INFORMATION_UPDATE
}

model Character {
  id String @id @default(uuid())

  userId      String
  roleClassId String?

  name                 String
  description          String?
  professionalFunction String?

  fatigueLimit   Int @default(3)
  currentFatigue Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats CharacterStats?
  items CharacterItem[]

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleClass           RoleClass?           @relation(fields: [roleClassId], references: [id], onDelete: SetNull)
  sessionParticipants SessionParticipant[]
  decisions           Decision[]

  @@index([userId])
  @@index([roleClassId])
}

model CharacterStats {
  id          String @id @default(uuid())
  characterId String @unique

  strength     Int
  dexterity    Int
  constitution Int
  intelligence Int
  wisdom       Int
  charisma     Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model ItemTemplate {
  id          String  @id @default(uuid())
  name        String
  type        String?
  description String?

  effects Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characterItems  CharacterItem[]
  allowedSessions SessionAllowedItemTemplate[]
}

model CharacterItem {
  id             String  @id @default(uuid())
  characterId    String
  itemTemplateId String?

  nameSnapshot String
  quantity     Int    @default(1)

  notes String?

  type    String?
  effects Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character    Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemTemplate ItemTemplate? @relation(fields: [itemTemplateId], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([itemTemplateId])
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  name     String
  role     UserRole @default(PARTICIPANT)

  characters        Character[]
  createdScenarios  Scenario[]    @relation("ScenarioCreator")
  moderatedSessions GameSession[] @relation("SessionModerator")
  teamMembers       TeamMember[]
  decisions         Decision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleClass {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  characters      Character[]
  allowedSessions SessionAllowedRoleClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id          String  @id @default(uuid())
  name        String
  companyName String?
  description String?

  members  TeamMember[]
  sessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id         String  @id @default(uuid())
  teamId     String
  userId     String
  roleInTeam String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Scenario {
  id          String         @id @default(uuid())
  title       String
  description String
  domain      ScenarioDomain
  goal        String
  difficulty  Int            @default(1)

  createdById String
  createdBy   User   @relation("ScenarioCreator", fields: [createdById], references: [id], onDelete: Cascade)

  tasks    ScenarioTask[]
  sessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model ScenarioTask {
  id             String  @id @default(uuid())
  scenarioId     String
  title          String
  description    String
  taskType       String
  expectedResult String?

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([scenarioId])
}

model GameSession {
  id          String        @id @default(uuid())
  scenarioId  String
  teamId      String?
  moderatorId String
  status      SessionStatus @default(PLANNED)

  scenario  Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  moderator User     @relation("SessionModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  participants SessionParticipant[]
  events       SessionEvent[]
  decisions    Decision[]
  metrics      TeamMetric?
  report       SessionReport?

  allowedRoleClasses   SessionAllowedRoleClass[]
  allowedItemTemplates SessionAllowedItemTemplate[]

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([scenarioId])
  @@index([teamId])
  @@index([moderatorId])
}

model SessionAllowedRoleClass {
  id          String @id @default(uuid())
  sessionId   String
  roleClassId String

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  roleClass RoleClass   @relation(fields: [roleClassId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roleClassId])
  @@index([sessionId])
  @@index([roleClassId])
}

model SessionAllowedItemTemplate {
  id             String @id @default(uuid())
  sessionId      String
  itemTemplateId String

  session      GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemTemplate ItemTemplate @relation(fields: [itemTemplateId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemTemplateId])
  @@index([sessionId])
  @@index([itemTemplateId])
}

model SessionParticipant {
  id          String @id @default(uuid())
  sessionId   String
  characterId String

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sessionId, characterId])
  @@index([sessionId])
  @@index([characterId])
}

model SessionEvent {
  id          String    @id @default(uuid())
  sessionId   String
  title       String
  description String
  eventType   EventType
  impact      String?

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  decisions Decision[]

  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Decision {
  id          String  @id @default(uuid())
  sessionId   String
  characterId String?
  userId      String?
  eventId     String?

  description      String
  result           String?
  moderatorComment String?
  score            Int?

  session   GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character?    @relation(fields: [characterId], references: [id], onDelete: SetNull)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     SessionEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([characterId])
  @@index([userId])
  @@index([eventId])
}

model TeamMetric {
  id        String @id @default(uuid())
  sessionId String @unique

  communicationScore      Int     @default(0)
  decisionSpeedScore      Int     @default(0)
  roleDistributionScore   Int     @default(0)
  conflictResolutionScore Int     @default(0)
  leadershipScore         Int     @default(0)
  comment                 String?

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionReport {
  id        String @id @default(uuid())
  sessionId String @unique

  summary           String
  successfulActions String?
  problemActions    String?
  recommendations   String?

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
