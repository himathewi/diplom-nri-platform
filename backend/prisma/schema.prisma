generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MODERATOR
  PARTICIPANT
}

enum SessionStatus {
  PLANNED
  ACTIVE
  FINISHED
}

enum EventType {
  PRODUCTION_PROBLEM
  WEATHER_CHANGE
  RESOURCE_LIMIT
  EQUIPMENT_FAILURE
  TEAM_CONFLICT
  INFORMATION_UPDATE
  QUALITY_ISSUE
  SAFETY_RISK
  TASK_UPDATE
}

enum ItemType {
  TOOL
  DOCUMENT
  COMMUNICATION
  SENSOR
  SAMPLE
  TRANSPORT
  RESOURCE
  OTHER
}

enum TaskType {
  MAIN
  SIDE
  OPTIONAL
}

enum SessionTaskStatus {
  PLANNED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum InvitationType {
  LINK
  CODE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  name     String
  role     UserRole @default(PARTICIPANT)

  characters           Character[]
  createdScenarios     Scenario[]           @relation("ScenarioCreator")
  moderatedSessions    GameSession[]        @relation("SessionModerator")
  teamMembers          TeamMember[]
  sessionParticipants  SessionParticipant[]
  decisions            Decision[]           @relation("DecisionAuthor")
  sentInvitations      SessionInvitation[]  @relation("InvitationSender")
  receivedInvitations  SessionInvitation[]  @relation("InvitationUser")
  createdTaskTemplates TaskTemplate[]       @relation("TaskTemplateCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleClass {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  characters      Character[]
  allowedSessions SessionAllowedRoleClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Character {
  id String @id @default(uuid())

  userId      String
  roleClassId String?

  name                 String
  description          String?
  professionalFunction String?

  fatigueLimit   Int @default(3)
  currentFatigue Int @default(0)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleClass RoleClass? @relation(fields: [roleClassId], references: [id], onDelete: SetNull)

  stats               CharacterStats?
  sessionParticipants SessionParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([roleClassId])
}

model CharacterStats {
  id          String @id @default(uuid())
  characterId String @unique

  strength     Int
  dexterity    Int
  constitution Int
  intelligence Int
  wisdom       Int
  charisma     Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Team {
  id          String  @id @default(uuid())
  name        String
  companyName String?
  description String?

  members  TeamMember[]
  sessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id         String  @id @default(uuid())
  teamId     String
  userId     String
  roleInTeam String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model ScenarioDirection {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)

  scenarios     Scenario[]
  taskTemplates TaskTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Scenario {
  id          String @id @default(uuid())
  title       String
  description String
  goal        String
  difficulty  Int    @default(1)

  directionId String?
  createdById String

  isPublicTemplate Boolean @default(false)

  direction ScenarioDirection? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  createdBy User               @relation("ScenarioCreator", fields: [createdById], references: [id], onDelete: Cascade)

  tasks    ScenarioTask[]
  sessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([directionId])
  @@index([createdById])
}

model ScenarioTask {
  id          String   @id @default(uuid())
  scenarioId  String
  title       String
  description String
  taskType    TaskType @default(MAIN)

  difficulty         Int     @default(1)
  fatigueCost        Int     @default(0)
  expectedResult     String?
  moderatorNotes     String?
  isVisibleByDefault Boolean @default(false)

  scenario     Scenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sessionTasks SessionTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scenarioId])
}

model TaskTemplate {
  id          String   @id @default(uuid())
  title       String
  description String
  taskType    TaskType @default(MAIN)

  directionId String?
  createdById String?

  difficulty     Int     @default(1)
  fatigueCost    Int     @default(0)
  expectedResult String?
  moderatorNotes String?
  isPublic       Boolean @default(false)
  isActive       Boolean @default(true)

  direction ScenarioDirection? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  createdBy User?              @relation("TaskTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  sessionTasks SessionTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([directionId])
  @@index([createdById])
}

model GameSession {
  id          String        @id @default(uuid())
  scenarioId  String
  teamId      String?
  moderatorId String
  status      SessionStatus @default(PLANNED)

  scenario  Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  moderator User     @relation("SessionModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  participants       SessionParticipant[]
  invitations        SessionInvitation[]
  events             SessionEvent[]
  decisions          Decision[]
  tasks              SessionTask[]
  metrics            TeamMetric?
  report             SessionReport?
  allowedRoleClasses SessionAllowedRoleClass[]
  allowedItems       SessionAllowedItem[]

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([scenarioId])
  @@index([teamId])
  @@index([moderatorId])
}

model SessionParticipant {
  id          String  @id @default(uuid())
  sessionId   String
  userId      String
  characterId String?

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)

  items     ParticipantItem[]
  decisions Decision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, userId])
  @@unique([sessionId, characterId])
  @@index([sessionId])
  @@index([userId])
  @@index([characterId])
}

model SessionInvitation {
  id            String  @id @default(uuid())
  sessionId     String
  invitedById   String
  invitedUserId String?

  type          InvitationType
  status        InvitationStatus @default(PENDING)
  tokenHash     String?          @unique
  codeHash      String?          @unique
  attemptsCount Int              @default(0)

  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  invitedBy   User        @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser User?       @relation("InvitationUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([invitedById])
  @@index([invitedUserId])
}

model SessionAllowedRoleClass {
  id          String @id @default(uuid())
  sessionId   String
  roleClassId String

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  roleClass RoleClass   @relation(fields: [roleClassId], references: [id], onDelete: Cascade)

  @@unique([sessionId, roleClassId])
  @@index([sessionId])
  @@index([roleClassId])
}

model Item {
  id          String   @id @default(uuid())
  name        String
  type        ItemType @default(OTHER)
  description String?

  attributeEffects Json?
  isPublic         Boolean @default(false)
  isActive         Boolean @default(true)

  allowedSessions  SessionAllowedItem[]
  participantItems ParticipantItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionAllowedItem {
  id        String @id @default(uuid())
  sessionId String
  itemId    String

  quantity  Int     @default(1)
  isVisible Boolean @default(true)
  notes     String?

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, itemId])
  @@index([sessionId])
  @@index([itemId])
}

model ParticipantItem {
  id                   String  @id @default(uuid())
  sessionParticipantId String
  itemId               String?

  nameSnapshot String
  quantity     Int     @default(1)
  notes        String?
  isUsed       Boolean @default(false)

  sessionParticipant SessionParticipant @relation(fields: [sessionParticipantId], references: [id], onDelete: Cascade)
  item               Item?              @relation(fields: [itemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionParticipantId])
  @@index([itemId])
}

model SessionTask {
  id String @id @default(uuid())

  sessionId        String
  scenarioTaskId   String?
  sourceTemplateId String?

  title                      String
  descriptionForModerator    String?
  descriptionForParticipants String?
  taskType                   TaskType          @default(MAIN)
  status                     SessionTaskStatus @default(PLANNED)

  difficulty              Int     @default(1)
  fatigueCost             Int     @default(0)
  isVisibleToParticipants Boolean @default(false)
  result                  String?

  session        GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scenarioTask   ScenarioTask? @relation(fields: [scenarioTaskId], references: [id], onDelete: SetNull)
  sourceTemplate TaskTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  decisions      Decision[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([sessionId])
  @@index([scenarioTaskId])
  @@index([sourceTemplateId])
}

model SessionEvent {
  id          String    @id @default(uuid())
  sessionId   String
  title       String
  description String
  eventType   EventType
  impact      String?

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  decisions Decision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

model Decision {
  id                   String  @id @default(uuid())
  sessionId            String
  sessionParticipantId String?
  userId               String?
  eventId              String?
  sessionTaskId        String?

  description      String
  result           String?
  moderatorComment String?
  score            Int?

  session            GameSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionParticipant SessionParticipant? @relation(fields: [sessionParticipantId], references: [id], onDelete: SetNull)
  user               User?               @relation("DecisionAuthor", fields: [userId], references: [id], onDelete: SetNull)
  event              SessionEvent?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sessionTask        SessionTask?        @relation(fields: [sessionTaskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([sessionParticipantId])
  @@index([userId])
  @@index([eventId])
  @@index([sessionTaskId])
}

model TeamMetric {
  id        String @id @default(uuid())
  sessionId String @unique

  communicationScore      Int     @default(0)
  decisionSpeedScore      Int     @default(0)
  roleDistributionScore   Int     @default(0)
  conflictResolutionScore Int     @default(0)
  leadershipScore         Int     @default(0)
  comment                 String?

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionReport {
  id        String @id @default(uuid())
  sessionId String @unique

  summary           String
  successfulActions String?
  problemActions    String?
  recommendations   String?

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
